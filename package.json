    },
    "devDependencies": {
        "@eslint/js": "^9.22.0",
        "@jest/globals": "^29.7.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.13.10",
        "eslint": "^9.22.0",
        "eslint-config-prettier": "^10.1.1",
        "eslint-plugin-jest": "^28.11.0",
        "jest": "^29.7.0",
        "prettier": "^3.5.3",
        "ts-jest": "^29.2.6",
        "ts-node": "^10.9.2",
        "tsup": "^8.4.0",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.26.1"
    }
